BOT_TOKEN=
MONGO_URI=
TELEGRAM_MODE=polling
WEBHOOK_URL=
PORT=3000
NEWS_CRON=*/30 * * * *
NEWS_NOTIFICATION_MIN_SCORE=65
ADMIN_CHAT_IDS=
# Môi trường chạy bot: local | production (dùng để định danh khi gõ /ping)
APP_ENV=local

# AI Provider: gemini | openai | groq | openrouter
AI_PROVIDER=openrouter

# Google Gemini API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano

# Groq API
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter API (supports free models like google/gemini-2.5-flash:free)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash:free

# Đường dẫn đến instance RSSHub
RSSHUB_URL=http://localhost:1200

# Nguồn tin tức: dev | mxh
FEED_SOURCE=dev
